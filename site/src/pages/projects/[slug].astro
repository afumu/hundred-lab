---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { MarkdownArticle } from '../../components/MarkdownArticle';
import { buildContentIndex, getEntryByKindAndSlug } from '../../lib/content';

export async function getStaticPaths() {
  const { projects } = await buildContentIndex();

  return projects.map((entry) => ({
    params: { slug: entry.slug },
  }));
}

const entry = await getEntryByKindAndSlug('project', Astro.params.slug ?? '');

if (!entry) {
  throw new Error(`Project not found for slug: ${Astro.params.slug}`);
}
---

<BaseLayout title={`${entry.title} · 百创计划`} description={entry.summary}>
  <article class="shell article-shell">
    <div>
      <p class="eyebrow">项目</p>
      <h1>{entry.title}</h1>
      <p>{entry.summary}</p>
      {entry.repo && (
        <p>
          <a href={entry.repo} target="_blank" rel="noreferrer">查看 GitHub 仓库</a>
        </p>
      )}
    </div>
    <MarkdownArticle markdown={entry.readme ?? ''} />
  </article>
</BaseLayout>
